generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Owner (Calendar owner) - singleton
// ============================================================================

model Owner {
  id                 String   @id @default("owner")
  name               String
  email              String
  description        String?
  avatar             String?
  bookingMonthsAhead Int      @default(3) // 1-12 months

  // WorkingHours are embedded in Owner (not a separate table)
  workingHoursStart  String   @default("09:00") // format HH:MM
  workingHoursEnd    String   @default("17:00") // format HH:MM
  workingDays        String   @default("[\"mon\",\"tue\",\"wed\",\"thu\",\"fri\"]") // JSON array of DayOfWeek

  // Relation to TimeOff (one-to-many)
  timeOffs           TimeOff[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ============================================================================
// TimeOff (Days off/vacations)
// ============================================================================

model TimeOff {
  id            String   @id @default(cuid())
  startDateTime DateTime
  endDateTime   DateTime

  // Relation to Owner
  owner         Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId       String   @default("owner")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([startDateTime, endDateTime])
}

// ============================================================================
// EventType (Event types - 30 min, 60 min, etc.)
// ============================================================================

model EventType {
  id              String    @id @default(cuid())
  title           String
  durationMinutes Int       // 15-480 minutes

  // Relation to Booking
  bookings        Booking[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ============================================================================
// Booking (Bookings)
// ============================================================================

model Booking {
  id          String   @id @default(cuid())
  startTime   DateTime
  endTime     DateTime // calculated based on EventType.durationMinutes

  // Guest is embedded in Booking (not a separate table)
  guestName   String
  guestEmail  String

  // Relation to EventType (Restrict - prevent deleting EventType if bookings exist)
  eventType   EventType @relation(fields: [eventTypeId], references: [id], onDelete: Restrict)
  eventTypeId String

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Index for fast search by time (for overlap checking)
  @@index([startTime, endTime])
  @@index([guestEmail])
}
